# Copy this file to .env and fill in values before running
# Never commit the real .env file

# Redis connection (used by API and worker)
REDIS_HOST=redis
REDIS_PORT=6379

# Frontend service
FRONTEND_PORT=3000
API_URL=http://api:8000

# Deploy secrets (used only by the GitHub Actions deploy job)
# DEPLOY_HOST=your.server.ip
# DEPLOY_USER=ubuntu
# DEPLOY_KEY=<contents of your SSH private key>
